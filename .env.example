# Database
DATABASE_URL="file:./dev.db"

# Site
NEXT_PUBLIC_SITE_URL=https://www.inklog.cn

# JWT
JWT_SECRET="change-me-to-a-random-64-char-string"

# IP Hash Salt
IP_HASH_SALT="change-me-to-a-random-32-char-string"

# SMTP (QQ Mail or any SMTP provider)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-auth-code
SMTP_FROM=your-email@qq.com

# Site verification cookie signing secret
SITE_SECRET=change-me-to-a-random-64-char-hex-string
